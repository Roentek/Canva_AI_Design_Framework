# API Keys and Environment Variables
# Fill in your real values below — NEVER commit this file

# === Tavily ===
 # Tavily API key
TAVILY_API_KEY=""    

# === Supabase ===
# Supabase personal access token (MCP)
SUPABASE_API_PAT=""                       
# e.g. https://xyzabc.supabase.co
SUPABASE_PROJECT_URL=""                   
# anon/service role key from Supabase dashboard
SUPABASE_PROJECT_KEY=""                                                            

# === OpenRouter ===
# OpenRouter URL
OPENROUTER_URL=https://openrouter.ai/api/v1
# OpenRouter API key
OPENROUTER_API_KEY=        
# OpenRouter model to use for answer generation (default: auto) 
OPENROUTER_MODEL=openrouter/auto              
# OPENROUTER_MODEL=anthropic/claude-sonnet-4    
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5  
# OPENROUTER_MODEL=anthropic/claude-opus-4
# OPENROUTER_MODEL=anthropic/claude-opus-4-5

# === Canva ===
# Canva MCP uses browser-based OAuth (no keys needed in .env)
# Authentication happens automatically when the MCP server starts
# The Canva MCP server URL is: https://mcp.canva.com/mcp
# See: https://www.canva.dev/docs/mcp/